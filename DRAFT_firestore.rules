rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth-Based Role Lookups
    // Note: isAdmin() uses a trusted collection
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isRestaurantOwner(restaurantId) {
      return isSignedIn() && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid;
    }

    // --- User Profiles ---
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 100 &&
             data.role in ['customer', 'restaurant', 'rider'] &&
             data.status in ['active', 'blocked', 'pending'] &&
             data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isVerified() && isValidUser(incoming()) && 
                    incoming().role == 'customer' && // Default role
                    incoming().status == 'pending'; // Requires approval or active on first sign
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'profileImage'])
      );
    }

    // --- Restaurants ---
    function isValidRestaurant(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.ownerId == request.auth.uid &&
             data.status in ['pending', 'approved', 'closed'];
    }

    match /restaurants/{restaurantId} {
      allow read: if true; // Public listings
      allow create: if isVerified() && isValidRestaurant(incoming()) && incoming().status == 'pending';
      allow update: if (isRestaurantOwner(restaurantId) || isAdmin()) && (
        (isRestaurantOwner(restaurantId) && incoming().diff(existing()).affectedKeys().hasOnly(['description', 'address', 'location', 'image', 'isOpen', 'categories'])) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'deliveryFee', 'rating']))
      );
    }

    // --- products ---
    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             isValidId(data.restaurantId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isRestaurantOwner(incoming().restaurantId) && isValidProduct(incoming());
      allow update: if isRestaurantOwner(existing().restaurantId) && isValidProduct(incoming()) &&
                    incoming().restaurantId == existing().restaurantId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'image', 'status']);
      allow delete: if isRestaurantOwner(existing().restaurantId);
    }

    // --- Orders ---
    function isValidOrder(data) {
      return data.customerId == request.auth.uid &&
             isValidId(data.restaurantId) &&
             data.status == 'pending' &&
             data.total is number && data.total >= 0;
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (
        isOwner(existing().customerId) || 
        isRestaurantOwner(existing().restaurantId) ||
        (existing().riderId != null && isOwner(existing().riderId)) ||
        isAdmin()
      );
      allow list: if isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        get(/databases/$(database)/documents/restaurants/$(resource.data.restaurantId)).data.ownerId == request.auth.uid ||
        resource.data.riderId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isVerified() && isValidOrder(incoming()) &&
                    exists(/databases/$(database)/documents/restaurants/$(incoming().restaurantId));
      allow update: if isSignedIn() && (
        // Restaurant Status Updates
        (isRestaurantOwner(existing().restaurantId) && incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
         incoming().status in ['accepted', 'preparing', 'ready', 'cancelled']) ||
        // Rider status Updates
        (isOwner(existing().riderId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         incoming().status in ['delivering', 'delivered']) ||
        // Rider self-assignment (if status is 'ready' and no rider assigned)
        (isVerified() && existing().status == 'ready' && existing().riderId == null &&
         incoming().diff(existing()).affectedKeys().hasOnly(['riderId', 'status', 'updatedAt']) &&
         incoming().riderId == request.auth.uid && incoming().status == 'delivering') ||
        isAdmin()
      );
    }
  }
}
